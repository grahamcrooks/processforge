    <participant id="pool_4" name="Employer/Group" processRef="proc_4"/>
    <messageFlow id="mf_1" sourceRef="step_12" targetRef="step_16"/>
  </collaboration>

  <!-- CUSTOMER -->
  <process id="proc_1" name="Customer" isExecutable="true">
