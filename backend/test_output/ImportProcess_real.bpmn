             name="6.2.3.1.1 Process a change of cover (Current state architecture) - Organizational Process Diagram">

  <collaboration id="collab_1">
    <participant id="pool_1" name="Customer" processRef="proc_1"/>
    <participant id="pool_2" name="HI Partnership Solutions Consultant R" processRef="proc_2"/>
